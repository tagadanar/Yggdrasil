# Node modules
node_modules/
**/node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build directories
**/dist/
**/.next/
**/build/

# TypeScript cache
**/*.tsbuildinfo

# Environment files - NEVER commit these!
.env
.env.*.local
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
**/*.env

# Secrets and credentials - Security critical!
secrets/
credentials/
keys/
certificates/
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
config/secrets.json
auth.json

# OS & Editor junk
.DS_Store
Thumbs.db

# IDE configs
.vscode/
.idea/

# Coverage & test output
coverage/
**/coverage/
*.lcov

# Playwright artifacts
playwright-report/
test-results/
*.zip

# Jest cache
jest-cache/
jest-output/

# Local database or temp files
scripts/setup-database.js.log
*.sqlite
*.db

# Uploaded files that might contain sensitive data
uploads/
**/uploads/
user-uploads/
profile-photos/
temp-files/

# Lint/formatter logs
.eslintcache
.prettier-cache

# Optional: lockfiles, if you're using only one package manager
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

